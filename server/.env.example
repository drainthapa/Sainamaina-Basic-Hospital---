# Server
NODE_ENV=development
PORT=5000
# Comma-separated list if running multiple frontends locally (e.g. admin panel + public site
# on different Vite ports). Defaults to both standard Vite dev ports if left unset.
CLIENT_URL=http://localhost:5173,http://localhost:5174

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hospital_portal
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# JWT
JWT_ACCESS_SECRET=change_this_to_a_long_random_string_access
JWT_REFRESH_SECRET=change_this_to_a_long_random_string_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# File storage: local | cloudinary | s3
STORAGE_PROVIDER=local
UPLOAD_DIR=../uploads
MAX_FILE_SIZE_MB=10

# Cloudinary (only needed if STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AWS S3 (only needed if STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
